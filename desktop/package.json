{
  "name": "ai-analyst-desktop",
  "version": "1.0.0",
  "description": "AI Analyst Desktop App",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder build --win"
  },
  "dependencies": {
    "electron-serve": "^1.3.0"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.aianalyst.desktop",
    "productName": "AI Analyst",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "dir"
    },
    "extraResources": [
      {
        "from": "../backend/dist/backend-api.exe",
        "to": "backend-api.exe"
      },
      {
        "from": "../frontend/out",
        "to": "frontend"
      }
    ]
  }
}
